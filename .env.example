PORT=3000

# Public wss:// / https:// host for this app (e.g. your ngrok subdomain), no trailing slash
PUBLIC_HOSTNAME=your-subdomain.ngrok-free.app

TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550001111

# Human agent's PSTN number for warm transfer
AGENT_PSTN_NUMBER=+15552223333

OPENAI_API_KEY=sk-proj-...

# Conversation Orchestrator configuration ID for real-time call summaries.
# Leave unset to skip the live-summary pipeline and always use the OpenAI fallback.
# Produced by `node scripts/setup-intelligence.js` (run after PUBLIC_HOSTNAME is set).
TWILIO_CONVERSATION_CONFIG_ID=

# Optional: override the pre-built Summary operator ID used by the setup script.
# TWILIO_SUMMARY_OPERATOR_ID=intelligence_operator_01kcv35pnkeysaf6z6cqtbpegn
